{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "lint": {},
    "start": {
      "persistent": true,
      "cache": false
    }
  },
  "globalEnv": [
    "SKIP_ENV_VALIDATION",
    "NODE_ENV",
    "BETTER_AUTH_SECRET",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "HONO_APP_URL",
    "HONO_PORT",
    "HONO_TRUSTED_ORIGINS",
    "HONO_RATE_LIMIT",
    "HONO_RATE_LIMIT_WINDOW_MS",
    "POSTGRES_URL",
    "REDIS_URL",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "ADMIN_EMAILS",
    "TURNSTILE_SECRET_KEY",
    "SARVAM_API_KEY",
    "ENABLE_EVIDENCE_SCRAPING",
    "LLM_RATE_LIMIT_PER_MINUTE",
    "LLM_MAX_RETRIES",
    "WORKER_TYPE",
    "WORKER_CONCURRENCY",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_NODE_ENV",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
    "NEXT_PUBLIC_POSTHOG_HOST",
    "NEXT_PUBLIC_POSTHOG_KEY",
    "NEXT_PUBLIC_USERJOT_URL",
    "INTERNAL_API_URL"
  ]
}
